{
  "version": 2,
  "functions": {
    "server/src/index.js": {
      "includeFiles": "server/node_modules/@ffmpeg-installer/**"
    }
  },
  "builds": [
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "app/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/src/index.js"
    },
    {
      "src": "/output/(.*)",
      "dest": "/server/src/index.js"
    },
    {
      "src": "/health",
      "dest": "/server/src/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}